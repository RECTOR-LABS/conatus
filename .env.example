# Conatus — copy to .env (gitignored). Never commit real values.
LLM_API_KEY=
LLM_MODEL=
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
AGENT_PRIVATE_KEY=
IPFS_PINNING_JWT=
IDENTITY_REGISTRY_ADDR=0x8004A818BFB912233c491871b3d84c89A494BD9e
ATTESTATION_ADDR=

# --- Contracts / deploy / verify ---
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz
MANTLE_MAINNET_CHAIN_ID=5000
ATTESTER_ADDRESS=
# Etherscan API V2 unified key — one key verifies contracts on every chain
# (replaces the deprecated per-explorer MantleScan V1 key; see contracts/foundry.toml).
ETHERSCAN_API_KEY=
# --- LLM via Ollama Cloud (OpenAI-compatible; glm-5.2 = Z.ai flagship, tools + 1M ctx) ---
# Base host is https://ollama.com/v1 (NOT api.ollama.com — it 301-redirects to ollama.com
# and the OpenAI SDK strips Authorization on cross-host redirects → 401).
# Model id is `glm-5.2` (the `:cloud` suffix is a CLI routing tag, invalid on the API).
# Get an Ollama Cloud API key at ollama.com (sign in → API keys).
LLM_BASE_URL=https://ollama.com/v1
# LLM_MODEL example: glm-5.2

# --- Agent HTTP service (Plan 5) ---
PORT=8787
CONATUS_API_TOKEN=
ALLOWED_ORIGIN=https://conatus.rectorspace.com
